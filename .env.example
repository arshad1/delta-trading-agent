# ===========================================================================
# Delta Exchange Trading Agent — Environment Configuration
# ===========================================================================

# ---------------------------------------------------------------------------
# Exchange (Delta Exchange)
# ---------------------------------------------------------------------------
DELTA_API_KEY=your_delta_api_key_here              # From https://demo.delta.exchange → Account → API Keys
DELTA_API_SECRET=your_delta_api_secret_here

# Testnet (demo account — safe for testing):
DELTA_BASE_URL=https://cdn-ind.testnet.deltaex.org
# Production (real funds — swap in when ready):
# DELTA_BASE_URL=https://api.india.delta.exchange

DELTA_LEVERAGE=5                                   # Leverage auto-set on every traded product at startup

# ---------------------------------------------------------------------------
# LLM Provider  —  pick ONE block below and fill in the key
# ---------------------------------------------------------------------------

# --- Option 1: Anthropic Claude (default, best reasoning + tool-use) -------
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5-20251101                 # or claude-sonnet-4-20250514, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# SANITIZE_MODEL=claude-haiku-4-5-20251001         # cheap model for output normalisation

# --- Option 2: OpenAI -------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o                                 # or gpt-4o-mini, o1, o3-mini
# OPENAI_API_KEY=sk-...

# --- Option 3: DeepSeek -----------------------------------------------------
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat                          # or deepseek-reasoner
# DEEPSEEK_API_KEY=sk-...

# --- Option 4: OpenRouter (1000+ models, single key) -----------------------
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct      # or anthropic/claude-opus-4-5, google/gemini-2.0-flash ...
# OPENROUTER_API_KEY=sk-or-...

# --- Option 5: Any OpenAI-compatible endpoint (Ollama, LM Studio, Groq …) --
# LLM_PROVIDER=openai_compat
# LLM_MODEL=llama3.2                               # whatever model name your server expects
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1  # Ollama default
# OPENAI_COMPAT_API_KEY=none                        # most local servers don't need a real key

# ---------------------------------------------------------------------------
# Trading config
# ---------------------------------------------------------------------------
ASSETS="BTC ETH SOL"                              # Perpetual futures underlying symbols (space-separated)
INTERVAL="5m"                                     # Decision interval: 1m 5m 15m 1h 4h

# ---------------------------------------------------------------------------
# Risk management  (all have sensible defaults)
# ---------------------------------------------------------------------------
MAX_POSITION_PCT=20                # Max single position as % of portfolio (default: 20)
MAX_LOSS_PER_POSITION_PCT=20       # Force-close at this % loss (default: 20)
MAX_LEVERAGE=10                    # Hard leverage cap (default: 10)
MAX_TOTAL_EXPOSURE_PCT=80          # Max total notional as % of portfolio (default: 80)
DAILY_LOSS_CIRCUIT_BREAKER_PCT=25  # Stop new trades at this daily drawdown % (default: 25)
MANDATORY_SL_PCT=5                 # Auto SL distance % if LLM doesn't set one (default: 5)
MAX_CONCURRENT_POSITIONS=10        # Max simultaneous positions (default: 10)
MIN_BALANCE_RESERVE_PCT=10         # Don't trade below this % of initial balance (default: 10)

# ---------------------------------------------------------------------------
# Optional / advanced
# ---------------------------------------------------------------------------
# ENABLE_TOOL_CALLING=false        # Let the LLM call fetch_indicator tool (Anthropic & OpenAI supported)
# THINKING_ENABLED=false           # Enable Claude extended thinking (Anthropic only)
# THINKING_BUDGET_TOKENS=10000     # Token budget for extended thinking
# MAX_TOKENS=4096                  # Max output tokens
# API_HOST=0.0.0.0
# API_PORT=3000
